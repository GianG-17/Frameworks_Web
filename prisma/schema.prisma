// Schema Prisma — Ponto Digital
// Banco: PostgreSQL (dev local via docker-compose; produção via Postgres gerenciado)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/lib/server/prisma-client"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id             String   @id @default(cuid())
  nome           String
  cnpj           String?  @unique
  horaAbertura   String   // "08:00"
  horaFechamento String   // "18:00"
  qrSecret       String   // segredo TOTP base32
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuarios       Usuario[]
  colaboradores  Colaborador[]
  jornadas       Jornada[]
  departamentos  Departamento[]
  registros      Registro[]
  ferias         Ferias[]
  justificativas Justificativa[]

  @@map("empresas")
}

// Usuário administrador — gerencia colaboradores, jornadas e dashboard.
model Usuario {
  id        String   @id @default(cuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  name      String
  email     String   @unique
  cpf       String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("usuarios")
}

// Colaborador — registra ponto via QR Code ou login manual.
model Colaborador {
  id             String        @id @default(cuid())
  empresaId      String
  empresa        Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  name           String
  email          String        @unique
  cpf            String        @unique
  password       String
  cargo          String?
  departamentoId String?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)
  telefone       String?
  dataAdmissao   DateTime?
  status         String?       // "ativo" | "inativo" | "ferias" | "afastado"
  jornadaId      String?
  jornada        Jornada?      @relation(fields: [jornadaId], references: [id], onDelete: SetNull)
  registros      Registro[]
  ferias         Ferias[]
  justificativas Justificativa[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([empresaId])
  @@map("colaboradores")
}

model Departamento {
  id            String        @id @default(cuid())
  empresaId     String
  empresa       Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome          String
  colaboradores Colaborador[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@map("departamentos")
}

model Jornada {
  id            String          @id @default(cuid())
  empresaId     String
  empresa       Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome          String
  colaboradores Colaborador[]
  // Versões do horário ao longo do tempo (vigência). O cálculo de datas passadas
  // resolve qual versão estava vigente no dia — alterar o horário não reescreve o histórico.
  versoes       JornadaVersao[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([empresaId])
  @@map("jornadas")
}

// Versão de horário de uma Jornada, válida a partir de `vigenciaInicio`.
// Versões já vigentes são imutáveis (histórico). Alteração de horário cria uma
// versão vigente a partir do dia seguinte; ver PUT /api/jornadas/[id].
model JornadaVersao {
  id             String   @id @default(cuid())
  jornadaId      String
  jornada        Jornada  @relation(fields: [jornadaId], references: [id], onDelete: Cascade)
  // JSON com os 7 dias (segunda..domingo)
  dias           Json
  vigenciaInicio DateTime @db.Date
  createdAt      DateTime @default(now())

  @@unique([jornadaId, vigenciaInicio])
  @@index([jornadaId, vigenciaInicio])
  @@map("jornada_versoes")
}

// Registro de ponto (batida) — imutável conforme Portaria 671/2021.
model Registro {
  id            String      @id @default(cuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  empresaId     String
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  type          String      // "entrada" | "saida_almoco" | "retorno_almoco" | "saida"
  timestamp     DateTime    @default(now())
  method        String      // "qrcode" | "manual"
  // Auditoria — Portaria 671/2021: registros são imutáveis.
  // createdBy preenchido apenas quando admin cria batida em nome de um colaborador (Usuario.id).
  createdBy     String?
  createdReason String?
  anulacao      RegistroAnulacao? @relation("registroAnulado")
  // Anulação que esta batida corrige (preenchido quando a batida nasceu de um ajuste).
  substituiAnulacao RegistroAnulacao? @relation("registroSubstituto")

  @@index([colaboradorId, timestamp])
  @@index([empresaId, timestamp])
  @@map("registros")
}

// Anulação de registro — complementa um Registro invalidando-o sem apagá-lo.
// Cálculo do espelho ignora registros com anulacao; AFD legal exporta ambos.
// Ajuste = anulação com `registroSubstitutoId` apontando para a batida corrigida.
// Anulação avulsa (ex.: clique duplicado) tem `registroSubstitutoId` nulo.
model RegistroAnulacao {
  id         String   @id @default(cuid())
  registroId String   @unique
  registro   Registro @relation("registroAnulado", fields: [registroId], references: [id], onDelete: Cascade)
  registroSubstitutoId String?   @unique
  registroSubstituto   Registro? @relation("registroSubstituto", fields: [registroSubstitutoId], references: [id], onDelete: SetNull)
  empresaId  String
  motivo     String
  anuladoPor String   // Usuario.id do admin
  anuladoEm  DateTime @default(now())

  @@index([empresaId])
  @@map("registro_anulacoes")
}

model Ferias {
  id            String      @id @default(cuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  empresaId     String
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  dataInicio    DateTime
  dataFim       DateTime
  observacao    String?
  createdAt     DateTime    @default(now())

  @@index([empresaId])
  @@index([colaboradorId])
  @@map("ferias")
}

model Justificativa {
  id            String      @id @default(cuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  empresaId     String
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  data          DateTime
  motivo        String
  anexoUrl      String?
  status        String      @default("pending") // "pending" | "approved" | "rejected"
  approvedBy    String?     // Usuario.id do admin que aprovou
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())
  @@index([status])

  @@index([empresaId])
  @@index([colaboradorId])
  @@map("justificativas")
}
