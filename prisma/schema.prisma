// Schema Prisma — Ponto Digital
// Banco: PostgreSQL (dev local via docker-compose; produção via Postgres gerenciado)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Empresa {
  id             String   @id @default(cuid())
  nome           String
  cnpj           String?  @unique
  horaAbertura   String   // "08:00"
  horaFechamento String   // "18:00"
  qrSecret       String   // segredo TOTP base32
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuarios       Usuario[]
  colaboradores  Colaborador[]
  jornadas       Jornada[]
  departamentos  Departamento[]
  punches        Punch[]
  ferias         Ferias[]
  justificativas Justificativa[]

  @@map("empresas")
}

// Usuário administrador — gerencia colaboradores, jornadas e dashboard.
model Usuario {
  id        String   @id @default(cuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  name      String
  email     String   @unique
  cpf       String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@map("usuarios")
}

// Colaborador — registra ponto via QR Code ou login manual.
model Colaborador {
  id             String        @id @default(cuid())
  empresaId      String
  empresa        Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  name           String
  email          String        @unique
  cpf            String        @unique
  password       String
  cargo          String?
  departamentoId String?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)
  telefone       String?
  dataAdmissao   DateTime?
  status         String?       // "ativo" | "inativo" | "ferias" | "afastado"
  jornadaId      String?
  jornada        Jornada?      @relation(fields: [jornadaId], references: [id], onDelete: SetNull)
  punches        Punch[]
  ferias         Ferias[]
  justificativas Justificativa[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([empresaId])
  @@map("colaboradores")
}

model Departamento {
  id            String        @id @default(cuid())
  empresaId     String
  empresa       Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome          String
  colaboradores Colaborador[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([empresaId, nome])
  @@index([empresaId])
  @@map("departamentos")
}

model Jornada {
  id            String        @id @default(cuid())
  empresaId     String
  empresa       Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome          String
  // JSON serializado com os 7 dias (segunda..domingo)
  dias          String
  colaboradores Colaborador[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([empresaId])
  @@map("jornadas")
}

model Punch {
  id            String      @id @default(cuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  empresaId     String
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  type          String      // "entrada" | "saida_almoco" | "retorno_almoco" | "saida"
  timestamp     DateTime    @default(now())
  method        String      // "qrcode" | "manual"
  latitude      Float?
  longitude     Float?
  // Auditoria — Portaria 671/2021: registros são imutáveis.
  // createdBy preenchido apenas quando admin cria batida em nome de um colaborador (Usuario.id).
  createdBy     String?
  createdReason String?
  anulacao      PunchAnulacao?

  @@index([colaboradorId, timestamp])
  @@index([empresaId, timestamp])
  @@map("punches")
}

// Anulação de batida — registro complementar que invalida um Punch sem apagá-lo.
// Cálculo do espelho ignora punches com anulacao; AFD legal exporta ambos.
model PunchAnulacao {
  id         String   @id @default(cuid())
  punchId    String   @unique
  punch      Punch    @relation(fields: [punchId], references: [id], onDelete: Cascade)
  empresaId  String
  motivo     String
  anuladoPor String   // Usuario.id do admin
  anuladoEm  DateTime @default(now())

  @@index([empresaId])
  @@map("punch_anulacoes")
}

model Ferias {
  id            String      @id @default(cuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  empresaId     String
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  dataInicio    DateTime
  dataFim       DateTime
  observacao    String?
  createdAt     DateTime    @default(now())

  @@index([empresaId])
  @@index([colaboradorId])
  @@map("ferias")
}

model Justificativa {
  id            String      @id @default(cuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  empresaId     String
  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  data          DateTime
  motivo        String
  anexoUrl      String?
  status        String      @default("pending") // "pending" | "approved" | "rejected"
  approvedBy    String?     // Usuario.id do admin que aprovou
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())
  @@index([status])

  @@index([empresaId])
  @@index([colaboradorId])
  @@map("justificativas")
}
