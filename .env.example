POSTGRES_USER=ponto
POSTGRES_PASSWORD=ponto
POSTGRES_DB=ponto_digital
POSTGRES_PORT=5432

DATABASE_URL="postgresql://ponto:ponto@localhost:5432/ponto_digital?schema=public"

PORT=3050
ORIGIN=http://localhost:3050

JWT_SECRET="segredo123"

# URL pública usada para montar o link de recuperação de senha (cai em ORIGIN se ausente)
APP_URL=http://localhost:3050

# SMTP (recuperação de senha). Sem SMTP_HOST, o link é apenas logado no console (dev).
# Ex.: Mailtrap sandbox para testar sem domínio verificado.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ponto Digital <no-reply@pontodigital.app>"