# Postgres local pelo docker
DATABASE_URL="postgresql://ponto:ponto@localhost:5432/ponto_digital?schema=public"
DATABASE_URL_UNPOOLED="postgresql://ponto:ponto@localhost:5432/ponto_digital?schema=public"

# Neon (produção / banco em nuvem) — descomente e substitua quando precisar
# DATABASE_URL="chave"
# DATABASE_URL_UNPOOLED="chave"

# Segredo de assinatura dos tokens JWT. Gere um valor forte em produção
# (ex.: `openssl rand -base64 32`). Sem isso, usa-se um fallback inseguro de dev.
JWT_SECRET="dev-insecure-secret-trocar-em-producao"

# Domínio público da aplicação em produção (usado pela proteção CSRF do adapter-node).
# ORIGIN="https://seu-dominio.com"