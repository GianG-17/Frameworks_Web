{
	"openapi": "3.0.3",
	"info": {
		"title": "Ponto Digital API",
		"version": "1.0.0",
		"description": "API do sistema de ponto eletrônico. Implementada via SvelteKit `+server.ts` com persistência em PostgreSQL via Prisma. Autenticação por JWT (HS256, validade 12h) enviado no header `Authorization: Bearer <token>`.\n\nTodas as entidades são escopadas por empresa (multi-tenant): o admin só enxerga dados da própria empresa.\n\n**Credenciais de teste (seed):**\n- Admin: `admin@teste.com` / `Senha123`\n- Colaborador: `carlos@teste.com` / `Senha123`\n- Colaborador: `ana@teste.com` / `Senha123`"
	},
	"servers": [
		{
			"url": "/api",
			"description": "SvelteKit local (npm run dev)"
		}
	],
	"tags": [
		{ "name": "Autenticação" },
		{ "name": "Colaboradores" },
		{ "name": "Departamentos" },
		{ "name": "Jornadas" },
		{ "name": "Empresas" },
		{ "name": "Ponto" },
		{ "name": "Ajustes (admin)" },
		{ "name": "Relatórios" },
		{ "name": "Férias" },
		{ "name": "Justificativas" },
		{ "name": "Administração" }
	],
	"components": {
		"securitySchemes": {
			"BearerAuth": {
				"type": "http",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		},
		"schemas": {
			"User": {
				"type": "object",
				"required": ["id", "name", "email", "cpf", "role", "empresaId"],
				"properties": {
					"id": { "type": "string", "example": "clx123" },
					"name": { "type": "string", "example": "Carlos Souza" },
					"email": { "type": "string", "format": "email", "example": "carlos@teste.com" },
					"cpf": { "type": "string", "example": "11144477735" },
					"role": { "type": "string", "enum": ["admin", "colaborador"], "example": "colaborador" },
					"empresaId": { "type": "string", "example": "clxEmpresa" }
				}
			},
			"AuthResponse": {
				"type": "object",
				"required": ["token", "user"],
				"properties": {
					"token": {
						"type": "string",
						"description": "JWT assinado (HS256), validade 12h",
						"example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
					},
					"user": { "$ref": "#/components/schemas/User" }
				}
			},
			"LoginCredentials": {
				"type": "object",
				"required": ["identifier", "password"],
				"properties": {
					"identifier": {
						"type": "string",
						"description": "E-mail ou CPF do usuário",
						"example": "carlos@teste.com"
					},
					"password": { "type": "string", "format": "password", "example": "Senha123" }
				}
			},
			"ErrorResponse": {
				"type": "object",
				"required": ["error"],
				"properties": {
					"error": { "type": "string", "example": "Não autorizado" },
					"field": { "type": "string", "description": "Campo que causou o erro (opcional)" }
				}
			},
			"Anulacao": {
				"type": "object",
				"required": ["motivo", "anuladoPor", "anuladoEm"],
				"properties": {
					"motivo": { "type": "string" },
					"anuladoPor": { "type": "string", "description": "Usuario.id do admin" },
					"anuladoEm": { "type": "string", "format": "date-time" },
					"registroSubstitutoId": {
						"type": "string",
						"nullable": true,
						"description": "Batida corrigida que substituiu esta (ajuste). Nulo em anulação avulsa."
					}
				}
			},
			"Registro": {
				"type": "object",
				"required": ["id", "colaboradorId", "type", "timestamp", "method"],
				"properties": {
					"id": { "type": "string" },
					"colaboradorId": { "type": "string" },
					"type": {
						"type": "string",
						"enum": ["entrada", "saida_almoco", "retorno_almoco", "saida"],
						"example": "entrada"
					},
					"timestamp": {
						"type": "string",
						"format": "date-time",
						"example": "2026-01-08T08:00:00.000Z"
					},
					"method": { "type": "string", "enum": ["manual"], "example": "manual" },
					"createdBy": {
						"type": "string",
						"nullable": true,
						"description": "Usuario.id do admin (preenchido quando a batida foi criada/ajustada por um admin)"
					},
					"createdReason": { "type": "string", "nullable": true },
					"anulacao": {
						"nullable": true,
						"allOf": [{ "$ref": "#/components/schemas/Anulacao" }]
					}
				}
			},
			"DailySummary": {
				"type": "object",
				"required": ["date", "registros", "totalHours", "overtime", "deficit", "abonado"],
				"properties": {
					"date": { "type": "string", "format": "date", "example": "2026-01-08" },
					"registros": { "type": "array", "items": { "$ref": "#/components/schemas/Registro" } },
					"totalHours": {
						"type": "number",
						"description": "Horas trabalhadas (decimal)",
						"example": 8.5
					},
					"overtime": { "type": "number", "description": "Horas extras (decimal)", "example": 0.5 },
					"deficit": { "type": "number", "description": "Horas faltantes (decimal)", "example": 0 },
					"abonado": {
						"type": "boolean",
						"description": "Dia com justificativa aprovada (deficit zerado)"
					}
				}
			},
			"RegistroInput": {
				"type": "object",
				"required": ["type"],
				"properties": {
					"type": {
						"type": "string",
						"enum": ["entrada", "saida_almoco", "retorno_almoco", "saida"],
						"example": "entrada"
					}
				}
			},
			"RegistroManualInput": {
				"type": "object",
				"required": ["colaboradorId", "type", "timestamp", "reason"],
				"properties": {
					"colaboradorId": { "type": "string" },
					"type": {
						"type": "string",
						"enum": ["entrada", "saida_almoco", "retorno_almoco", "saida"]
					},
					"timestamp": {
						"type": "string",
						"format": "date-time",
						"description": "Não pode ser no futuro"
					},
					"reason": { "type": "string", "description": "Motivo (mínimo 5 caracteres)" }
				}
			},
			"RegistroAjusteInput": {
				"type": "object",
				"required": ["timestamp", "reason"],
				"properties": {
					"type": {
						"type": "string",
						"enum": ["entrada", "saida_almoco", "retorno_almoco", "saida"],
						"description": "Opcional — mantém o tipo original se omitido"
					},
					"timestamp": {
						"type": "string",
						"format": "date-time",
						"description": "Não pode ser no futuro"
					},
					"reason": { "type": "string", "description": "Motivo (mínimo 5 caracteres)" }
				}
			},
			"RegistroAnularInput": {
				"type": "object",
				"required": ["motivo"],
				"properties": {
					"motivo": { "type": "string", "description": "Motivo (mínimo 5 caracteres)" }
				}
			},
			"Colaborador": {
				"type": "object",
				"required": ["id", "nome", "email", "cpf", "status"],
				"properties": {
					"id": { "type": "string" },
					"nome": { "type": "string" },
					"email": { "type": "string", "format": "email" },
					"cpf": { "type": "string", "example": "111.444.777-35" },
					"cargo": { "type": "string" },
					"departamentoId": { "type": "string", "nullable": true },
					"departamento": {
						"type": "object",
						"nullable": true,
						"properties": {
							"id": { "type": "string" },
							"nome": { "type": "string" }
						}
					},
					"dataAdmissao": { "type": "string", "format": "date" },
					"status": { "type": "string", "enum": ["ativo", "inativo", "ferias", "afastado"] },
					"telefone": { "type": "string" },
					"jornadaId": { "type": "string" }
				}
			},
			"ColaboradorInput": {
				"type": "object",
				"required": ["nome", "email", "cpf"],
				"properties": {
					"nome": { "type": "string" },
					"email": { "type": "string", "format": "email" },
					"cpf": { "type": "string" },
					"cargo": { "type": "string" },
					"departamentoId": { "type": "string" },
					"dataAdmissao": { "type": "string", "format": "date" },
					"status": { "type": "string", "enum": ["ativo", "inativo", "ferias", "afastado"] },
					"telefone": { "type": "string" },
					"jornadaId": { "type": "string" }
				}
			},
			"DiaSemana": {
				"type": "object",
				"required": ["ativo", "entrada", "saida_almoco", "retorno_almoco", "saida"],
				"properties": {
					"ativo": { "type": "boolean" },
					"entrada": { "type": "string", "example": "08:00" },
					"saida_almoco": { "type": "string", "example": "12:00" },
					"retorno_almoco": { "type": "string", "example": "13:00" },
					"saida": { "type": "string", "example": "17:00" }
				}
			},
			"DiasSemana": {
				"type": "object",
				"properties": {
					"segunda": { "$ref": "#/components/schemas/DiaSemana" },
					"terca": { "$ref": "#/components/schemas/DiaSemana" },
					"quarta": { "$ref": "#/components/schemas/DiaSemana" },
					"quinta": { "$ref": "#/components/schemas/DiaSemana" },
					"sexta": { "$ref": "#/components/schemas/DiaSemana" },
					"sabado": { "$ref": "#/components/schemas/DiaSemana" },
					"domingo": { "$ref": "#/components/schemas/DiaSemana" }
				}
			},
			"JornadaVersao": {
				"type": "object",
				"required": ["vigenciaInicio", "dias"],
				"properties": {
					"vigenciaInicio": {
						"type": "string",
						"format": "date",
						"description": "Data (YYYY-MM-DD) a partir da qual esta versão vale"
					},
					"dias": { "$ref": "#/components/schemas/DiasSemana" }
				}
			},
			"Jornada": {
				"type": "object",
				"required": ["id", "nome", "dias", "versoes"],
				"properties": {
					"id": { "type": "string" },
					"nome": { "type": "string", "example": "Comercial 8h" },
					"dias": {
						"description": "Horário vigente hoje",
						"allOf": [{ "$ref": "#/components/schemas/DiasSemana" }]
					},
					"versoes": {
						"type": "array",
						"description": "Histórico de versões, em ordem crescente de vigência",
						"items": { "$ref": "#/components/schemas/JornadaVersao" }
					}
				}
			},
			"JornadaInput": {
				"type": "object",
				"required": ["nome", "dias"],
				"properties": {
					"nome": { "type": "string" },
					"dias": { "$ref": "#/components/schemas/DiasSemana" }
				}
			},
			"Departamento": {
				"type": "object",
				"required": ["id", "nome"],
				"properties": {
					"id": { "type": "string" },
					"nome": { "type": "string" }
				}
			},
			"DepartamentoInput": {
				"type": "object",
				"required": ["nome"],
				"properties": { "nome": { "type": "string" } }
			},
			"DepartamentoJornadaInput": {
				"type": "object",
				"required": ["jornadaId"],
				"properties": {
					"jornadaId": {
						"type": "string",
						"nullable": true,
						"description": "Jornada a aplicar a todos os colaboradores do departamento (null para desvincular)"
					}
				}
			},
			"Empresa": {
				"type": "object",
				"required": ["id", "nome", "horaAbertura", "horaFechamento"],
				"properties": {
					"id": { "type": "string" },
					"nome": { "type": "string" },
					"cnpj": { "type": "string", "nullable": true },
					"horaAbertura": { "type": "string", "example": "08:00" },
					"horaFechamento": { "type": "string", "example": "18:00" },
					"createdAt": { "type": "string", "format": "date-time" },
					"updatedAt": { "type": "string", "format": "date-time" }
				}
			},
			"EmpresaInput": {
				"type": "object",
				"required": ["nome", "horaAbertura", "horaFechamento"],
				"properties": {
					"nome": { "type": "string" },
					"cnpj": { "type": "string" },
					"horaAbertura": { "type": "string", "example": "08:00" },
					"horaFechamento": { "type": "string", "example": "18:00" }
				}
			},
			"Ferias": {
				"type": "object",
				"required": ["id", "colaboradorId", "dataInicio", "dataFim"],
				"properties": {
					"id": { "type": "string" },
					"colaboradorId": { "type": "string" },
					"colaboradorNome": { "type": "string" },
					"dataInicio": { "type": "string", "format": "date-time" },
					"dataFim": { "type": "string", "format": "date-time" },
					"observacao": { "type": "string", "nullable": true }
				}
			},
			"FeriasInput": {
				"type": "object",
				"required": ["colaboradorId", "dataInicio", "dataFim"],
				"properties": {
					"colaboradorId": { "type": "string" },
					"dataInicio": { "type": "string", "format": "date" },
					"dataFim": { "type": "string", "format": "date" },
					"observacao": { "type": "string" }
				}
			},
			"Justificativa": {
				"type": "object",
				"required": ["id", "colaboradorId", "data", "motivo", "status"],
				"properties": {
					"id": { "type": "string" },
					"colaboradorId": { "type": "string" },
					"colaboradorNome": { "type": "string" },
					"data": { "type": "string", "format": "date-time" },
					"motivo": { "type": "string" },
					"anexoUrl": { "type": "string", "nullable": true },
					"status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
					"approvedBy": { "type": "string", "nullable": true },
					"approvedAt": { "type": "string", "format": "date-time", "nullable": true }
				}
			},
			"JustificativaAdminInput": {
				"type": "object",
				"required": ["colaboradorId", "data", "motivo"],
				"properties": {
					"colaboradorId": { "type": "string" },
					"data": { "type": "string", "format": "date" },
					"motivo": { "type": "string" },
					"anexoUrl": { "type": "string" }
				}
			},
			"JustificativaMeInput": {
				"type": "object",
				"required": ["data", "motivo"],
				"properties": {
					"data": { "type": "string", "format": "date" },
					"motivo": { "type": "string" },
					"anexoUrl": { "type": "string" }
				}
			},
			"EspelhoDia": {
				"allOf": [
					{ "$ref": "#/components/schemas/DailySummary" },
					{
						"type": "object",
						"properties": {
							"original": {
								"type": "object",
								"description": "Totais considerando só as marcações do colaborador (sem ajustes do admin)",
								"properties": {
									"totalHours": { "type": "number" },
									"overtime": { "type": "number" },
									"deficit": { "type": "number" }
								}
							}
						}
					}
				]
			},
			"EspelhoTotais": {
				"type": "object",
				"properties": {
					"horas": { "type": "number" },
					"extras": { "type": "number" },
					"deficit": { "type": "number" }
				}
			},
			"EspelhoRelatorio": {
				"type": "object",
				"properties": {
					"colaborador": {
						"type": "object",
						"properties": { "id": { "type": "string" }, "nome": { "type": "string" } }
					},
					"inicio": { "type": "string", "format": "date" },
					"fim": { "type": "string", "format": "date" },
					"dias": { "type": "array", "items": { "$ref": "#/components/schemas/EspelhoDia" } },
					"totais": {
						"allOf": [
							{ "$ref": "#/components/schemas/EspelhoTotais" },
							{
								"type": "object",
								"properties": { "original": { "$ref": "#/components/schemas/EspelhoTotais" } }
							}
						]
					}
				}
			},
			"ConsolidadoLinha": {
				"type": "object",
				"properties": {
					"colaboradorId": { "type": "string" },
					"colaboradorNome": { "type": "string" },
					"diasTrabalhados": { "type": "integer" },
					"horas": { "type": "number" },
					"horasEsperadas": { "type": "number" },
					"extras": { "type": "number" },
					"deficit": { "type": "number" },
					"periodosFerias": { "type": "integer" },
					"faltasJustificadas": { "type": "integer" }
				}
			},
			"ConsolidadoRelatorio": {
				"type": "object",
				"properties": {
					"mes": { "type": "string", "example": "2026-01" },
					"linhas": {
						"type": "array",
						"items": { "$ref": "#/components/schemas/ConsolidadoLinha" }
					}
				}
			},
			"EntradaHoje": {
				"type": "object",
				"properties": {
					"colaboradorId": { "type": "string" },
					"nome": { "type": "string" },
					"jornadaEntrada": { "type": "string", "nullable": true, "example": "08:00" },
					"batidaEntrada": { "type": "string", "format": "date-time", "nullable": true },
					"atrasoMin": { "type": "integer" },
					"status": {
						"type": "string",
						"enum": ["pontual", "atrasado", "falta", "pendente", "folga", "sem_jornada"]
					}
				}
			},
			"DashboardMetrics": {
				"type": "object",
				"properties": {
					"referenciaData": { "type": "string", "format": "date" },
					"colaboradoresAtivos": { "type": "integer", "example": 2 },
					"totalColaboradores": { "type": "integer", "example": 6 },
					"totalColaboradoresRegistrados": { "type": "integer" },
					"pontosHoje": { "type": "integer", "example": 8 },
					"atrasosHoje": { "type": "integer" },
					"faltasHoje": { "type": "integer" },
					"justificativasMes": { "type": "integer" },
					"feriasAtivasNoMes": { "type": "integer" },
					"horasExtrasMes": { "type": "number", "example": 4.5 },
					"horasDeficitMes": { "type": "number", "example": 1.2 },
					"horasExtrasPorDia": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"date": { "type": "string", "format": "date" },
								"horas": { "type": "number" }
							}
						}
					},
					"topExtras": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"colaboradorId": { "type": "string" },
								"nome": { "type": "string" },
								"horas": { "type": "number" }
							}
						}
					},
					"entradasHoje": {
						"type": "array",
						"items": { "$ref": "#/components/schemas/EntradaHoje" }
					}
				}
			}
		}
	},
	"paths": {
		"/auth/login": {
			"post": {
				"operationId": "loginUser",
				"tags": ["Autenticação"],
				"summary": "Autenticar com e-mail ou CPF e senha",
				"requestBody": {
					"required": true,
					"content": {
						"application/json": { "schema": { "$ref": "#/components/schemas/LoginCredentials" } }
					}
				},
				"responses": {
					"200": {
						"description": "Login realizado com sucesso",
						"content": {
							"application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } }
						}
					},
					"400": {
						"description": "Corpo da requisição inválido",
						"content": {
							"application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
						}
					},
					"401": {
						"description": "Credenciais inválidas",
						"content": {
							"application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
						}
					}
				}
			}
		},
		"/auth/logout": {
			"post": {
				"operationId": "logoutUser",
				"tags": ["Autenticação"],
				"summary": "Encerrar sessão do usuário",
				"security": [{ "BearerAuth": [] }],
				"responses": {
					"204": { "description": "Sessão encerrada com sucesso" }
				}
			}
		},
		"/auth/me": {
			"get": {
				"operationId": "getCurrentUser",
				"tags": ["Autenticação"],
				"summary": "Retornar dados do usuário autenticado",
				"security": [{ "BearerAuth": [] }],
				"responses": {
					"200": {
						"description": "Dados do usuário",
						"content": {
							"application/json": { "schema": { "$ref": "#/components/schemas/User" } }
						}
					},
					"401": {
						"description": "Não autenticado",
						"content": {
							"application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
						}
					}
				}
			}
		},
		"/colaboradores": {
			"get": {
				"operationId": "listColaboradores",
				"tags": ["Colaboradores"],
				"summary": "Listar colaboradores da empresa",
				"security": [{ "BearerAuth": [] }],
				"responses": {
					"200": {
						"description": "Lista de colaboradores",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": { "$ref": "#/components/schemas/Colaborador" }
								}
							}
